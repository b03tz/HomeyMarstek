  "flow": {
    "triggers": [
      {
        "title": {
          "en": "Total power changed"
        },
        "hint": {
          "en": "Triggered when the meter total power reading changes"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=marstek-meter"
          }
        ],
        "tokens": [
          {
            "name": "power",
            "type": "number",
            "title": {
              "en": "Power (W)"
            },
            "example": {
              "en": "-500"
            }
          }
        ],
        "id": "meter_power_changed"
      },
      {
        "title": {
          "en": "Operating mode changed"
        },
        "hint": {
          "en": "Triggered when the battery operating mode changes"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=marstek-battery"
          }
        ],
        "tokens": [
          {
            "name": "mode",
            "type": "string",
            "title": {
              "en": "Mode"
            },
            "example": {
              "en": "Auto"
            }
          }
        ],
        "id": "mode_changed"
      }
    ],
    "conditions": [
      {
        "title": {
          "en": "Phase [[phase]] power is !{{above|below}} [[power]] W"
        },
        "titleFormatted": {
          "en": "Phase [[phase]] power is !{{above|below}} [[power]] W"
        },
        "hint": {
          "en": "Check if a specific phase power is above or below a threshold"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=marstek-meter"
          },
          {
            "type": "dropdown",
            "name": "phase",
            "title": {
              "en": "Phase"
            },
            "values": [
              {
                "id": "a",
                "title": {
                  "en": "A"
                }
              },
              {
                "id": "b",
                "title": {
                  "en": "B"
                }
              },
              {
                "id": "c",
                "title": {
                  "en": "C"
                }
              }
            ]
          },
          {
            "type": "number",
            "name": "power",
            "title": {
              "en": "Power (W)"
            },
            "min": -10000,
            "max": 10000,
            "step": 10
          }
        ],
        "id": "meter_phase_above"
      },
      {
        "title": {
          "en": "Total power is !{{above|below}} [[power]] W"
        },
        "titleFormatted": {
          "en": "Total power is !{{above|below}} [[power]] W"
        },
        "hint": {
          "en": "Check if the total grid power is above or below a threshold (negative = exporting)"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=marstek-meter"
          },
          {
            "type": "number",
            "name": "power",
            "title": {
              "en": "Power (W)"
            },
            "min": -10000,
            "max": 10000,
            "step": 10
          }
        ],
        "id": "meter_power_above"
      },
      {
        "title": {
          "en": "Mode is !{{|not}} [[mode]]"
        },
        "titleFormatted": {
          "en": "Mode is !{{|not}} [[mode]]"
