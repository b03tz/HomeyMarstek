                }
              },
              {
                "id": "Passive",
                "title": {
                  "en": "Passive"
                }
              },
              {
                "id": "Ups",
                "title": {
                  "en": "UPS"
                }
              }
            ]
          }
        ],
        "id": "mode_is"
      }
